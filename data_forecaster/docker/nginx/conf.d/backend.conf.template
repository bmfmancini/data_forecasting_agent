# Backend Nginx configuration (envsubst template).
#
# Variables substituted at container start:
#   ${BACKEND_HTTPS_PORT}  - HTTPS listen port (default 8443)
#   ${BACKEND_UPSTREAM}    - upstream uvicorn service:port (default backend:8000)

server {
    listen ${BACKEND_HTTPS_PORT} ssl;
    server_name _;

    ssl_certificate     /etc/nginx/certs/server.crt;
    ssl_certificate_key /etc/nginx/certs/server.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # Allow large uploads (CSV/XLSX).  Match MAX_UPLOAD_MB on the backend.
    client_max_body_size 256m;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host  $host;

    proxy_http_version 1.1;
    proxy_read_timeout  300s;
    proxy_send_timeout  300s;

    location / {
        proxy_pass http://${BACKEND_UPSTREAM};
    }
}