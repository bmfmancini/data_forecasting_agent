# --- LLM Configuration ---
# Set to 'true' to use local Ollama instead of Google Gemini
USE_OLLAMA=false

# Google Gemini Settings (Required if USE_OLLAMA=false)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=8192

# Ollama Settings (Required if USE_OLLAMA=true)
# Set to 'true' to use Ollama Cloud (https://ollama.com) instead of a local Ollama daemon.
# When true, OLLAMA_API_KEY is REQUIRED (create one at https://ollama.com/settings/keys)
# and OLLAMA_MODEL must be a cloud-capable model (e.g. gemma4:31b-cloud).
# See https://ollama.com/search?c=cloud for the list of supported cloud models.
USE_OLLAMA_CLOUD=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=


# --- Backend Configuration ---
# Max file upload size in MB (defaults to 100 in config.py)
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=csv,xlsx
CHROMA_PERSIST_DIR=./chroma_db

# API authentication: defaults to 'false' (open mode — no auth required).
# Auth is enabled at runtime via the admin panel's "Enable Authentication"
# workflow, which calls POST /api-users/bootstrap on the backend.
# On restart, the backend auto-re-enables auth if API users exist in the DB.
API_KEY_ENABLED=false

# --- Frontend Configuration ---
BACKEND_URL=http://localhost:8000

# Deployment-time admin key used to protect the one-time bootstrap endpoint
# (POST /api-users/bootstrap).  Set this to a strong random value and share
# it with the admin who will enable API authentication via the admin panel.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me-to-a-strong-random-value

# Flask session encryption (required for decrypting stored backend API credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FLASK_ENCRYPTION_KEY=generate-a-fernet-key-and-paste-here
FLASK_SECRET_KEY=change-me-in-production