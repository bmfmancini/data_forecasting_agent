# --- LLM Configuration ---
# Set to 'true' to use local Ollama instead of Google Gemini
USE_OLLAMA=false

# Google Gemini Settings (Required if USE_OLLAMA=false)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=8192

# Ollama Settings (Required if USE_OLLAMA=true)
OLLAMA_BASE_URL=
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=

# --- Backend Configuration ---
# Max file upload size in MB (defaults to 100 in config.py)
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=csv,xlsx
CHROMA_PERSIST_DIR=./chroma_db

# --- Frontend Configuration ---
BACKEND_URL=http://localhost:8000