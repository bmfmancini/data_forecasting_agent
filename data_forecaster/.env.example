GROQ_API_KEY=
# Groq model to use. See https://console.groq.com/docs/models for available models.
# Examples: llama-3.3-70b-versatile | llama3-8b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=1
GROQ_MAX_COMPLETION_TOKENS=8192
GROQ_TOP_P=1
# Reasoning effort — only supported by reasoning models (e.g. deepseek-r1-distill-llama-70b)
# Values: none | low | medium | high | default  (ignored by non-reasoning models)
GROQ_REASONING_EFFORT=medium
MAX_UPLOAD_MB=10
ALLOWED_EXTENSIONS=csv,xlsx
