# --- LLM Configuration ---
# Set to 'true' to use local Ollama instead of Google Gemini
USE_OLLAMA=false

# Google Gemini Settings (Required if USE_OLLAMA=false)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1

# Ollama Settings (Required if USE_OLLAMA=true)
# Set USE_OLLAMA_CLOUD=true to use Ollama Cloud instead of a local daemon.
# When true, OLLAMA_API_KEY is REQUIRED and OLLAMA_MODEL must be cloud-capable.
USE_OLLAMA_CLOUD=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=

# --- Backend Configuration ---
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=csv,xlsx
CHROMA_PERSIST_DIR=./chroma_db
FILE_STORAGE_DIR=./file_store
API_KEY_DB_PATH=./data
MAX_INMEMORY_FILES=50
MAX_INMEMORY_JOBS=100

# Token budget configurations for LLM prompts (in tokens)
REPORT_GENERATION_TOKEN_BUDGET=800
FORECASTING_TOKEN_BUDGET=400
DATA_VALIDATION_TOKEN_BUDGET=300
MODEL_SELECTION_TOKEN_BUDGET=300
STATISTICAL_ANALYSIS_TOKEN_BUDGET=300

# API authentication (defaults to false — open mode).
# Enabled at runtime via the admin panel bootstrap workflow.
API_KEY_ENABLED=false

# Deployment-time admin key protecting the one-time bootstrap endpoint.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me-to-a-strong-random-value

# Pre-shared frontend API credentials for Docker deployments.
# When both are set, the backend auto-creates a 'frontend' API user on
# first startup and the frontend auto-stores the credentials in its DB.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
FRONTEND_API_USERNAME=frontend
FRONTEND_API_KEY=generate-a-strong-random-key-here

# --- Frontend Configuration ---
BACKEND_URL=http://localhost:8000

###Default admin login credentials for inital login.
##The admin will be forced to change the password on first login.
FRONTEND_ADMIN_USERNAME=admin
FRONTEND_ADMIN_PASSWORD=admin

# Flask session secret (required in production).
SECRET_KEY=change-me-in-production

# Fernet key for encrypting stored backend API credentials.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
##Examplke key rKHHDRtoZs6tYhUeWRMG5SvmnLplqq6G5bJhRJregrY=  ##No this is not a real key
FLASK_ENCRYPTION_KEY=generate-a-fernet-key-and-paste-here