# --- Frontend Configuration ---

# Flask session secret (required in production).
# Generate with: python ../backend/scripts/bootstrap.py
SECRET_KEY=change-me-in-production

# Fernet key for encrypting stored backend API credentials.
# Generate with: python ../backend/scripts/bootstrap.py
FLASK_ENCRYPTION_KEY=generate-a-fernet-key-and-paste-here

# Optional path to demo CSV data.
# DEMO_DATA_PATH=/absolute/path/to/demo_data.csv
