# --- Frontend Configuration ---
FLASK_ENV=development
BACKEND_URL=http://localhost:8000
API_VERIFY_SSL=false
MAX_UPLOAD_MB=100

# Default admin login credentials for initial login.
# The admin will be forced to change the password on first login.
FRONTEND_ADMIN_USERNAME=admin
FRONTEND_ADMIN_PASSWORD=admin

# Flask session secret (required in production).
# Generate with: python ../backend/scripts/bootstrap.py
SECRET_KEY=change-me-in-production

# Fernet key for encrypting stored backend API credentials.
# Generate with: python ../backend/scripts/bootstrap.py
FLASK_ENCRYPTION_KEY=generate-a-fernet-key-and-paste-here

# Pre-shared backend service-account credentials.
# These values must match the backend's FRONTEND_API_USERNAME and FRONTEND_API_KEY.
# Generate matching values with: python ../backend/scripts/bootstrap.py
FRONTEND_API_USERNAME=frontend
FRONTEND_API_KEY=generate-a-strong-random-key-here

# Optional path to demo CSV data.
# DEMO_DATA_PATH=/absolute/path/to/demo_data.csv
